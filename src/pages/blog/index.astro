---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');

// Group articles by category
const grouped: Record<string, typeof articles> = {};
for (const article of articles) {
  const cat = article.data.category;
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(article);
}

// Sort categories alphabetically, and articles within each category by date (newest first)
const sortedCategories = Object.keys(grouped).sort();
---

<Layout
  title="Blog — drop.js"
  description="Guides, comparisons, and tutorials on headless CMS architecture and drop.js."
>
  <main class="blog-page">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Blog</span>
        <h1 class="section-title">Guides, Comparisons & Tutorials</h1>
        <p class="section-subtitle">Everything you need to know about headless CMS architecture, migration strategies, and building with drop.js.</p>
      </div>

      {sortedCategories.map((category) => (
        <div class="blog-category">
          <h2 class="blog-category-title">{category}</h2>
          <div class="blog-grid">
            {grouped[category].map((article) => (
              <a href={`/blog/${article.id}`} class="blog-card">
                <span class="blog-card-category">{article.data.category}</span>
                <h3 class="blog-card-title">{article.data.title}</h3>
                <p class="blog-card-excerpt">{article.data.excerpt}</p>
                <div class="blog-card-meta">
                  <span>{article.data.date}</span>
                  <span>&middot;</span>
                  <span>{article.data.readTime}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

